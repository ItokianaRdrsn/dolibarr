  "date": "2024-06-25",
  "type": "transport",
  "amount": 45.50,
  "description": "Train Paris-Lyon",
  "status": 0
}

### Valider une note de frais
POST {{baseUrl}}/expensereports/1/validate
Content-Type: application/json
Accept: application/json
DOLAPIKEY: {{apiKey}}

### Supprimer une note de frais
DELETE {{baseUrl}}/expensereports/1
Content-Type: application/json
Accept: application/json
DOLAPIKEY: {{apiKey}}

